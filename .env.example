# ============================================================
# Cause & Counsel — environment variables
# Copy this file to .env for local dev, and set the SAME keys in
# the Vercel dashboard (Project → Settings → Environment Variables).
# .env itself is gitignored and must never be committed.
# ============================================================

# --- EmailJS (forms) — PUBLIC, served to the browser via /api/config ---
# emailjs.com → Account → API Keys (public key); Email Services; the template ID
EMAILJS_PUBLIC_KEY=
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=

# --- Google Calendar (events) — PUBLIC, served via /api/config ---
# Restrict the API key by HTTP referrer (your domain) in Google Cloud Console.
GCAL_CALENDAR_ID=
GCAL_API_KEY=

# --- Notion (blog CMS) — SECRET, server-side only (used by /api/posts) ---
# This token is NEVER sent to the browser. notion.so/my-integrations
NOTION_TOKEN=
NOTION_DB_ID=
